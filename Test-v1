ortance_heatmap(df, brand_name):\n    # 1. Lấy các loại tấn công phổ biến (bỏ Benign để soi rõ Attack)\n    attack_df = df[df['state'] != 'BENIGN']\n    top_attacks = attack_df['state'].value_counts().nlargest(5).index.tolist()\n    \n    importance_data = []\n    \n    # 2. Tính mức độ quan trọng cho từng loại tấn công cụ thể\n    for attack in top_attacks:\n        # Tạo bài toán nhị phân: Attack cụ thể vs Benign\n        binary_df = pd.concat([\n            df[df['state'] == 'BENIGN'].sample(5000, random_state=42),\n            df[df['state'] == attack].sample(min(len(df[df['state'] == attack]), 5000), random_state=42)\n        ])\n        \n        X = binary_df[current_numeric_cols].fillna(0)\n        y = (binary_df['state'] == attack).astype(int)\n        \n        # Train nhanh RF để lấy Feature Importance\n        rf = RandomForestClassifier(n_estimators=50, random_state=42, n_jobs=-1)\n        rf.fit(X, y)\n        importance_data.append(rf.feature_importances_)\n    \n    # 3. Tạo DataFrame cho Heatmap (Lấy top 15 đặc trưng quan trọng nhất tổng thể)\n    importance_df = pd.DataFrame(importance_data, columns=current_numeric_cols, index=top_attacks)\n    top_15_features = importance_df.mean().nlargest(15).index\n    final_heatmap_df = importance_df[top_15_features].T\n    \n    # 4. Vẽ Heatmap\n    plt.figure(figsize=(12, 10))\n    sns.heatmap(final_heatmap_df, annot=True, cmap='YlGnBu', fmt=\".3f\")\n    plt.title(f\"Mức độ quan trọng của Đặc trưng theo Tấn công - {brand_name}\", fontsize=14)\n    plt.ylabel(\"Đặc trưng (Features)\")\n    plt.xlabel(\"Loại tấn công (Attacks)\")\n    plt.show()\n\n# Thực thi cho Schneider và Siemens\nplot_feature_importance_heatmap(large_mini_df[large_mini_df['brand'] == 'Schneider'], \"Schneider\")\nplot_feature_importance_heatmap(large_mini_df[large_mini_df['brand'] == 'Siemens'], \"Siemens\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T17:46:53.230874Z","iopub.execute_input":"2026-04-02T17:46: