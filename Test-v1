 scaler.fit_transform(X_selected)\n    \n    print(\"HOÀN TẤT TIỀN XỬ LÝ VÀ CHỌN LỌC ĐẶC TRƯNG\")\n    return X_scaled, y, metadata, selected_features, label_encoder, scaler","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T17:46:57.088673Z","iopub.execute_input":"2026-04-02T17:46:57.089111Z","iopub.status.idle":"2026-04-02T17:46:57.096071Z","shell.execute_reply.started":"2026-04-02T17:46:57.089087Z","shell.execute_reply":"2026-04-02T17:46:57.095438Z"}},"outputs":[],"execution_count":13},{"cell_type":"markdown","source":"","metadata":{}},{"cell_type":"markdown","source":"**TRÍCH XUẤT ĐẶC TRƯNG VỚI FT-TRANSFORMER**","metadata":{}},{"cell_type":"code","source":"import torch\nimport torch.nn as nn\nfrom torch.nn import TransformerEncoderLayer, TransformerEncoder\n\nclass TabularFeatureTokenizer(nn.Module):\n    \"\"\"\n    Tokenizer chuyên dụng cho dữ liệu dạng bảng (Tabular Data).\n    Khác với hình ảnh hay văn bản, mỗi cột đặc trưng thống kê cần một \n    bộ trọng số biến đổi (weight & bias) hoàn toàn độc lập.\n    \"\"\"\n    def __init__(self, num_features=15, embedding_dim=640):\n        super(TabularFeatureTokenizer, self).__init__()\n        self.num_features = num_features\n        self.embedding_dim = embedding_dim\n        \n        # 1. Trọng số và Bias RIÊNG BIỆT cho từng đặc trưng\n        # Khởi tạo ma trận trọng số có kích thước [num_features, embedding_dim]\n        self.weight = nn.Parameter(torch.Tensor(num_features, embedding_dim))\n        self.bias = nn.Parameter(torch.Tensor(num_features, embedding_dim))\n        \n        # Khởi tạo giá trị (dùng phân phối chuẩn hoặc Kaiming)\n        nn.init.normal_(self.weight, std=0.01)\n        nn.init.zeros_(self.bias)\n\n    def forward(self, x):\n        # Đầu vào x có kích thước: [batch_size, num_features]\n        # Thêm 1 chiều để nhân ma trận: [batch_size, num_features, 1]\n        x = x.unsqueeze(-1)\n        \n        # Biến đổi tuyến tính: x_i * W_i + b_i\n        # Đầu ra tokens có kích thước: [batch_size, num_features, embedding_dim]\n        tokens = x * self.weight + self.bias\n        return tokens\n\n\nclass FT_Transformer_Backbone(nn.Module):\n    \"\"\"\n    Mạng FT-Transformer Backbone kết hợp Tokenizer và Self-Attention.\n    \"\"\"\n    def __init__(self, num_features=15, embedding_dim=640, num_layers=3, nhead=8, dropout=0.1):\n        super(FT_Transformer_Backbone, self).__init__()\n        \n        # 1. Khởi tạo bộ Tokenizer\n        self.tokenizer = TabularFeatureTokenizer(num_features, embedding_dim)\n        \n        # 2. Khởi tạo token đại diện toàn cục [CLS]\n        # Giống như BERT, token này sẽ học cách tổng hợp ngữ cảnh của toàn bộ các đặc trưng\n        self.cls_token = nn.Parameter(torch.Tensor(1, 1, embedding_dim))\n        nn.init.normal_(self.cls_token, std=0.01)\n        \n        # 3. Khối Transformer Encoder (Self-Attention)\n        encoder_layer = TransformerEncoderLayer(\n            d_model=embedding_dim,\n            nhead=nhead,\n            dim_feedforward=embedding_dim * 2, # Thường là d_model * 2 hoặc 4\n            dropout=dropout,\n            batch_first=True # Bắt buộc True để giữ nguyên thứ tự [batch_size, seq_len, d_model]\n        )\n        self.transformer = TransformerEncoder(encoder_layer, num_layers=num_layers)\n        \n    def forward(self, x):\n        batch_size = x.size(0)\n        \n        # Bước 1: Băm các con số thập phân thành Feature Tokens\n        # Kích thước: [batch_size, num_features, embedding_dim]\n        feature_tokens = self.tokenizer(x)\n        \n        # Bước 2: Chuẩn bị token [CLS] cho toàn bộ batch\n        # Kích thước: [batch_size, 1, embedding_dim]\n        cls_tokens = self.cls_token.expand(batch_size, -1, -1)\n        \n        # Bước 3: Ghép nối [CLS] vào đầu chuỗi đặc trưng\n        # Kích thước: [batch_size, 1 + num_features, embedding_dim]\n        transformer_input = torch.cat((cls_tokens, feature_tokens), dim=1)\n        \n        # Bước 4: Đưa qua các lớp Self-Attention\n        # Mạng sẽ tự động tính toán mức độ quan trọng chéo giữa các đặc trưng (ví dụ: cờ TCP vs Payload)\n        transformer_output = self.transformer(transformer_input)\n        \n        # Bước 5: Trích xuất không gian biểu diễn (Latent Representation)\n        # Chỉ lấy vector tại vị trí 0 (chính là token [CLS] sau khi đã học xong bối cảnh)\n        global_representation = transformer_output[:, 0, :]\n        \n        return global_representation # Kích thước đầu ra: [batch_size, embedding_dim]","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T17:46:57.098770Z","iopub.execute_input":"2026-04-02T17:46:57.099145Z","iopub.status.idle":"2026-04-02T17:47:01.146394Z","shell.execute_reply.started":"2026-04-02T17:46:57.099120Z","shell.execute_reply":"2026-04-02T17:47:01.145800Z"}},"outputs":[],"execution_count":14},{"cell_type":"markdown","source":"# **code** ","metadata":{}},{"cell_type":"code","source":"# ============================================================================\n# CELL 1: SETUP & IMPORTS\n# ============================================================================\n\nimport os\nimport glob\nimport gc\nimport numpy as np\nimport pandas as pd\nimport cudf\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch.utils.data import Dataset, DataLoader, Sampler\nfrom sklearn.ensemble import RandomForestClassifier\nfrom sklearn.preprocessing import StandardScaler, LabelEncoder\nimport random\nfrom tqdm import tqdm\nimport warnings\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nimport pickle\n\nwarnings.filterwarnings('ignore')\n\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nprint(f\"🎯 Device: {device}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T17:47:01.147365Z","iopub.execute_input":"2026-04-02T17:47:01.147978Z","iopub.status.idle":"2026-04-02T17:47:01.161145Z","shell.execute_reply.started":"2026-04-02T17:47:01.